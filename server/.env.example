# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Gemini AI ────────────────────────────────────────
# Get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Email (Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CareerSync <no-reply@careersync.io>"

# ─── Frontend ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Encryption ───────────────────────────────────────
# AES-256-GCM key for portal credentials (username/password)
CREDENTIALS_ENCRYPTION_KEY=change_this_credentials_key_min_32_chars
# AES-256-GCM key for screening Q&A answers (falls back to CREDENTIALS_ENCRYPTION_KEY if not set)
ANSWER_ENCRYPTION_KEY=change_this_answer_key_min_32_chars_here

# ─── Google OAuth (Gmail Sync) ────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable Gmail API
# 3. OAuth consent screen → Add test user (your email)
# 4. Credentials → OAuth 2.0 Client ID (Web application)
# 5. Add redirect URI: http://localhost:5000/api/v1/gmail/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/gmail/callback
